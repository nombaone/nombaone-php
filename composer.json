{
    "name": "nombaone/nombaone-php",
    "description": "Official PHP SDK for the NombaOne subscription-billing API — recurring billing for Nigeria over card, direct debit, and bank transfer.",
    "type": "library",
    "keywords": [
        "nombaone",
        "nomba",
        "billing",
        "subscriptions",
        "payments",
        "nigeria",
        "api",
        "sdk"
    ],
    "homepage": "https://docs.nombaone.xyz",
    "license": "MIT",
    "authors": [
        {
            "name": "Nomba One",
            "homepage": "https://nombaone.xyz"
        }
    ],
    "support": {
        "docs": "https://docs.nombaone.xyz",
        "issues": "https://github.com/nombaone/nombaone-php/issues",
        "source": "https://github.com/nombaone/nombaone-php"
    },
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.8",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "suggest": {
        "guzzlehttp/guzzle": "A PSR-18 HTTP client and PSR-17 factories the SDK can auto-discover (^7.8).",
        "symfony/http-client": "An alternative PSR-18 HTTP client the SDK can auto-discover (^6.4 || ^7.0)."
    },
    "autoload": {
        "psr-4": {
            "NombaOne\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NombaOne\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite unit,conformance",
        "test:unit": "phpunit --testsuite unit",
        "test:conformance": "phpunit --testsuite conformance",
        "test:integration": "phpunit --testsuite integration",
        "verify": "php bin/full-surface-verify.php",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": [
            "@cs:check",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
