# Keep the published Composer package lean — dev-only files are export-ignored
# and never end up in `composer require` installs.
/.github            export-ignore
/bin                export-ignore
/examples           export-ignore
/spec               export-ignore
/tests              export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/.php-cs-fixer.dist.php export-ignore
/phpstan.neon.dist  export-ignore
/phpunit.xml.dist   export-ignore
/SUMMARY.md         export-ignore
